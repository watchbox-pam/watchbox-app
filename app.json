{
  "expo": {
    "name": "Watchbox",
    "slug": "watchbox-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#FFFFFF",
    "icon": "./src/assets/images/watchbox-logo.png",
	"scheme": "watchbox-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.watchbox.watchbox",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:app.watchbox-app.fr"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/watchbox-logo.png",
        "backgroundColor": "#102A4C"
      },
      "package": "com.watchbox.watchbox",
      "backgroundColor": "#102A4C",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.watchbox-app.fr",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-video",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5cafa03b-bbf2-4cf1-9519-15dfb1af5f58"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5cafa03b-bbf2-4cf1-9519-15dfb1af5f58"
    }
  }
}
