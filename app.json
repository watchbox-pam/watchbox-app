{
	"expo": {
		"name": "Watchbox",
		"slug": "watchbox-app",
		"version": "1.0.0",
		"orientation": "portrait",

		"backgroundColor": "#FFFFFF",

		"icon": "./src/assets/images/watchbox-logo.png",
		"scheme": "myapp",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,

		"splash": {
			"image": "./src/assets/images/splash-icon.png",
			"resizeMode": "contain",
			"backgroundColor": "#000000"
		},

		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.watchbox.watchbox",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},

		"android": {
			"package": "com.watchbox.watchbox",
			"backgroundColor": "#102A4C",
			"adaptiveIcon": {
				"foregroundImage": "./src/assets/images/watchbox-logo.png",
				"backgroundColor": "#102A4C"
			}
		},

		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./src/assets/images/favicon.png"
		},

		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./src/assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#FFFFFF"
				}
			],
			"expo-video",
			"expo-secure-store",
			"expo-font",
			"expo-web-browser"
		],

		"experiments": {
			"typedRoutes": true
		},

		"extra": {
			"router": {
				"origin": false
			},
			"eas": {
				"projectId": "5cafa03b-bbf2-4cf1-9519-15dfb1af5f58"
			}
		},

		"runtimeVersion": {
			"policy": "appVersion"
		},

		"updates": {
			"url": "https://u.expo.dev/5cafa03b-bbf2-4cf1-9519-15dfb1af5f58"
		}
	}
}
